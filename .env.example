# Required for local dev and production (PostgreSQL)
# Get from Vercel Postgres, Neon, or any Postgres host
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# App URL (used in emails, Stripe redirects, etc.)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# Stripe (required for checkout / paid tiers)
# STRIPE_SECRET_KEY="sk_..."
# STRIPE_PRICE_ID="price_..."
# STRIPE_PRICE_ID_GUIDED="price_..."
# STRIPE_PRICE_ID_CONCIERGE="price_..."

# Optional: AI matching / typeform parsing
# ANTHROPIC_API_KEY="sk-ant-..."

# Optional: Analytics
# NEXT_PUBLIC_META_PIXEL_ID=""
# NEXT_PUBLIC_TIKTOK_PIXEL_ID=""
